# Neon Postgres DB
# DATABASE_URL=

# Local Postgres DB
DATABASE_URL=postgresql://postgres:password@localhost:5436/finnari-v0 

BETTER_AUTH_SECRET=randomly generated secure token
BETTER_AUTH_URL=http://localhost:3002 # Base URL of your app

DB_HOST=localhost
