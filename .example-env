# Backblaze B2 Cloud Storage Configuration
BACKBLAZE_ENDPOINT=https://s3.us-west-004.backblaze.com
BACKBLAZE_REGION=us-west-004
BACKBLAZE_KEY_ID=your_keyID_here
BACKBLAZE_APP_KEY=your_applicationKey_here
BACKBLAZE_BUCKET_NAME=your_bucket_name